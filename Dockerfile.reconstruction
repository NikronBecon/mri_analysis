FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY pyproject.toml README.md ./
COPY mri_analysis ./mri_analysis
COPY demo_checkpoint ./demo_checkpoint

RUN pip install --no-cache-dir ".[reconstruction]"

EXPOSE 8000

CMD ["uvicorn", "mri_analysis.reconstruction_service.main:create_app", "--factory", "--host", "0.0.0.0", "--port", "8000"]
